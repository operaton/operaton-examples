<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:operaton="http://operaton.org/schema/1.0/bpmn" targetNamespace="http://www.operaton.org/examples" exporter="operaton modeler" exporterVersion="1.0">
  <error id="PaymentFailed" name="Payment Failed" errorCode="PAYMENT_FAILED" />
  <collaboration id="Collaboration_OrderFulfillment">
    <participant id="Pool_OrderFulfillment" name="Order Fulfillment" processRef="order-fulfillment" />
  </collaboration>
  <process id="order-fulfillment" name="Order Fulfillment" isExecutable="true" operaton:historyTimeToLive="P30D" operaton:candidateStarterGroups="sales,operaton-admin">
    <laneSet id="LaneSet_1">
      <lane id="Lane_Sales" name="sales">
        <flowNodeRef>StartEvent_1</flowNodeRef>
      </lane>
      <lane id="Lane_Warehouse" name="warehouse">
        <flowNodeRef>Task_PackShip</flowNodeRef>
      </lane>
      <lane id="Lane_System" name="System">
        <flowNodeRef>Task_NotifyBackorder</flowNodeRef>
        <flowNodeRef>EndEvent_Failed</flowNodeRef>
        <flowNodeRef>Task_ChargePayment</flowNodeRef>
        <flowNodeRef>Gateway_InStock</flowNodeRef>
        <flowNodeRef>Task_ValidateInventory</flowNodeRef>
        <flowNodeRef>Task_NotifyCustomer</flowNodeRef>
        <flowNodeRef>EndEvent_Shipped</flowNodeRef>
        <flowNodeRef>EndEvent_Backordered</flowNodeRef>
        <flowNodeRef>ErrorBoundary_Payment</flowNodeRef>
      </lane>
    </laneSet>
    <startEvent id="StartEvent_1" name="Order Placed">
      <outgoing>Flow_start_to_inventory</outgoing>
    </startEvent>
    <userTask id="Task_PackShip" name="Pack &#38; Ship" operaton:candidateGroups="warehouse">
      <incoming>Flow_payment_to_pack</incoming>
      <outgoing>Flow_pack_to_notify</outgoing>
    </userTask>
    <sequenceFlow id="Flow_start_to_inventory" sourceRef="StartEvent_1" targetRef="Task_ValidateInventory" />
    <sequenceFlow id="Flow_inventory_to_gw" sourceRef="Task_ValidateInventory" targetRef="Gateway_InStock" />
    <sequenceFlow id="Flow_in_stock" name="in stock" sourceRef="Gateway_InStock" targetRef="Task_ChargePayment">
      <conditionExpression xsi:type="tFormalExpression">${available == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_out_of_stock" name="out of stock" sourceRef="Gateway_InStock" targetRef="Task_NotifyBackorder">
      <conditionExpression xsi:type="tFormalExpression">${available == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_payment_to_pack" sourceRef="Task_ChargePayment" targetRef="Task_PackShip" />
    <sequenceFlow id="Flow_pack_to_notify" sourceRef="Task_PackShip" targetRef="Task_NotifyCustomer" />
    <sequenceFlow id="Flow_notify_to_shipped" sourceRef="Task_NotifyCustomer" targetRef="EndEvent_Shipped" />
    <sequenceFlow id="Flow_backorder_to_end" sourceRef="Task_NotifyBackorder" targetRef="EndEvent_Backordered" />
    <sequenceFlow id="Flow_error_to_failed" sourceRef="ErrorBoundary_Payment" targetRef="EndEvent_Failed">
      <extensionElements>
        <operaton:executionListener event="take" expression="${execution.setVariable(&#39;orderStatus&#39;, &#39;FAILED&#39;)}" />
      </extensionElements>
    </sequenceFlow>
    <serviceTask id="Task_NotifyBackorder" name="Notify Backorder" operaton:delegateExpression="${notifyBackorderDelegate}">
      <incoming>Flow_out_of_stock</incoming>
      <outgoing>Flow_backorder_to_end</outgoing>
    </serviceTask>
    <endEvent id="EndEvent_Failed" name="Notify Customer of Failure">
      <incoming>Flow_error_to_failed</incoming>
    </endEvent>
    <serviceTask id="Task_ChargePayment" name="Charge Payment" operaton:delegateExpression="${paymentDelegate}" operaton:asyncBefore="true">
      <extensionElements>
        <operaton:failedJobRetryTimeCycle>R3/PT10S</operaton:failedJobRetryTimeCycle>
      </extensionElements>
      <incoming>Flow_in_stock</incoming>
      <outgoing>Flow_payment_to_pack</outgoing>
    </serviceTask>
    <boundaryEvent id="ErrorBoundary_Payment" attachedToRef="Task_ChargePayment">
      <outgoing>Flow_error_to_failed</outgoing>
      <errorEventDefinition errorRef="PaymentFailed" />
    </boundaryEvent>
    <exclusiveGateway id="Gateway_InStock" name="In Stock?">
      <incoming>Flow_inventory_to_gw</incoming>
      <outgoing>Flow_in_stock</outgoing>
      <outgoing>Flow_out_of_stock</outgoing>
    </exclusiveGateway>
    <serviceTask id="Task_ValidateInventory" name="Validate Inventory" operaton:delegateExpression="${inventoryDelegate}">
      <incoming>Flow_start_to_inventory</incoming>
      <outgoing>Flow_inventory_to_gw</outgoing>
    </serviceTask>
    <serviceTask id="Task_NotifyCustomer" name="Notify Customer" operaton:delegateExpression="${notifyCustomerDelegate}">
      <incoming>Flow_pack_to_notify</incoming>
      <outgoing>Flow_notify_to_shipped</outgoing>
    </serviceTask>
    <endEvent id="EndEvent_Shipped" name="Order Shipped">
      <incoming>Flow_notify_to_shipped</incoming>
    </endEvent>
    <endEvent id="EndEvent_Backordered" name="Order Backordered">
      <incoming>Flow_backorder_to_end</incoming>
    </endEvent>
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_OrderFulfillment">
      <bpmndi:BPMNShape id="Pool_OrderFulfillment_di" bpmnElement="Pool_OrderFulfillment" isHorizontal="true">
        <dc:Bounds x="160" y="20" width="1220" height="530" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_System_di" bpmnElement="Lane_System" isHorizontal="true">
        <dc:Bounds x="190" y="240" width="1190" height="310" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Warehouse_di" bpmnElement="Lane_Warehouse" isHorizontal="true">
        <dc:Bounds x="190" y="120" width="1190" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Sales_di" bpmnElement="Lane_Sales" isHorizontal="true">
        <dc:Bounds x="190" y="20" width="1190" height="100" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="252" y="62" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="237" y="38" width="65" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PackShip_di" bpmnElement="Task_PackShip">
        <dc:Bounds x="820" y="140" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_NotifyBackorder_di" bpmnElement="Task_NotifyBackorder">
        <dc:Bounds x="620" y="440" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Failed_di" bpmnElement="EndEvent_Failed">
        <dc:Bounds x="832" y="402" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="810" y="364.5" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ChargePayment_di" bpmnElement="Task_ChargePayment">
        <dc:Bounds x="620" y="290" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_InStock_di" bpmnElement="Gateway_InStock" isMarkerVisible="true">
        <dc:Bounds x="505" y="305" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="507" y="281" width="46" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ValidateInventory_di" bpmnElement="Task_ValidateInventory">
        <dc:Bounds x="310" y="290" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_NotifyCustomer_di" bpmnElement="Task_NotifyCustomer">
        <dc:Bounds x="1000" y="290" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Shipped_di" bpmnElement="EndEvent_Shipped">
        <dc:Bounds x="1202" y="312" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1185" y="355" width="72" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Backordered_di" bpmnElement="EndEvent_Backordered">
        <dc:Bounds x="832" y="462" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="819" y="505" width="63" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ErrorBoundary_Payment_di" bpmnElement="ErrorBoundary_Payment">
        <dc:Bounds x="682" y="352" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_start_to_inventory_di" bpmnElement="Flow_start_to_inventory">
        <di:waypoint x="270" y="98" />
        <di:waypoint x="270" y="330" />
        <di:waypoint x="310" y="330" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_inventory_to_gw_di" bpmnElement="Flow_inventory_to_gw">
        <di:waypoint x="450" y="330" />
        <di:waypoint x="505" y="330" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_in_stock_di" bpmnElement="Flow_in_stock">
        <di:waypoint x="555" y="330" />
        <di:waypoint x="620" y="330" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="564" y="310" width="38" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_out_of_stock_di" bpmnElement="Flow_out_of_stock">
        <di:waypoint x="530" y="355" />
        <di:waypoint x="530" y="480" />
        <di:waypoint x="620" y="480" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="539" y="445" width="57" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_payment_to_pack_di" bpmnElement="Flow_payment_to_pack">
        <di:waypoint x="760" y="330" />
        <di:waypoint x="890" y="330" />
        <di:waypoint x="890" y="220" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_pack_to_notify_di" bpmnElement="Flow_pack_to_notify">
        <di:waypoint x="960" y="180" />
        <di:waypoint x="1070" y="180" />
        <di:waypoint x="1070" y="290" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_notify_to_shipped_di" bpmnElement="Flow_notify_to_shipped">
        <di:waypoint x="1140" y="330" />
        <di:waypoint x="1202" y="330" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_backorder_to_end_di" bpmnElement="Flow_backorder_to_end">
        <di:waypoint x="760" y="480" />
        <di:waypoint x="832" y="480" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_error_to_failed_di" bpmnElement="Flow_error_to_failed">
        <di:waypoint x="700" y="388" />
        <di:waypoint x="700" y="420" />
        <di:waypoint x="832" y="420" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>

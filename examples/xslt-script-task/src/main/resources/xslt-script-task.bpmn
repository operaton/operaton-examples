<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:operaton="http://operaton.org/schema/1.0/bpmn"
                  id="Definitions_XsltScriptTask"
                  targetNamespace="http://operaton.org/examples">

  <bpmn:error id="Error_TransformError" name="Transform Error" errorCode="transform-error"/>

  <bpmn:process id="xslt-script-task" name="XSLT Script Task" isExecutable="true"
                operaton:historyTimeToLive="P30D">

    <bpmn:startEvent id="StartEvent_InputReceived" name="Input XML received">
      <bpmn:outgoing>Flow_ToTransform</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:scriptTask id="ScriptTask_Transform" name="Transform XML" scriptFormat="groovy">
      <bpmn:incoming>Flow_ToTransform</bpmn:incoming>
      <bpmn:outgoing>Flow_ToEnd</bpmn:outgoing>
      <bpmn:script><![CDATA[
import javax.xml.transform.TransformerFactory
import javax.xml.transform.stream.StreamSource
import javax.xml.transform.stream.StreamResult
import java.io.StringReader
import java.io.StringWriter
import org.operaton.bpm.engine.delegate.BpmnError

def xml = execution.getVariable("inputXml") as String
if (xml == null) throw new BpmnError("transform-error", "inputXml variable is missing")

def xslStream = Thread.currentThread().contextClassLoader
    .getResourceAsStream("org/operaton/examples/xsltscripttask/transform.xsl")
if (xslStream == null) throw new BpmnError("transform-error", "transform.xsl not found on classpath")

try {
    def factory = TransformerFactory.newInstance()
    def transformer = factory.newTransformer(new StreamSource(xslStream))
    def writer = new StringWriter()
    transformer.transform(new StreamSource(new StringReader(xml)), new StreamResult(writer))
    execution.setVariable("transformedXml", writer.toString())
} catch (Exception e) {
    throw new BpmnError("transform-error", e.getMessage())
}
      ]]></bpmn:script>
    </bpmn:scriptTask>

    <bpmn:boundaryEvent id="BoundaryEvent_TransformError" attachedToRef="ScriptTask_Transform">
      <bpmn:outgoing>Flow_ToErrorEnd</bpmn:outgoing>
      <bpmn:errorEventDefinition errorRef="Error_TransformError"/>
    </bpmn:boundaryEvent>

    <bpmn:endEvent id="EndEvent_Transformed" name="XML transformed">
      <bpmn:incoming>Flow_ToEnd</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_TransformFailed" name="Transformation failed">
      <bpmn:incoming>Flow_ToErrorEnd</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_ToTransform" sourceRef="StartEvent_InputReceived" targetRef="ScriptTask_Transform"/>
    <bpmn:sequenceFlow id="Flow_ToEnd" sourceRef="ScriptTask_Transform" targetRef="EndEvent_Transformed"/>
    <bpmn:sequenceFlow id="Flow_ToErrorEnd" sourceRef="BoundaryEvent_TransformError" targetRef="EndEvent_TransformFailed"/>
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_XsltScriptTask">
    <bpmndi:BPMNPlane id="BPMNPlane_XsltScriptTask" bpmnElement="xslt-script-task">
      <bpmndi:BPMNShape id="Shape_Start" bpmnElement="StartEvent_InputReceived">
        <dc:Bounds x="152" y="202" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="127" y="245" width="86" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_ScriptTask" bpmnElement="ScriptTask_Transform">
        <dc:Bounds x="240" y="180" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_BoundaryError" bpmnElement="BoundaryEvent_TransformError">
        <dc:Bounds x="272" y="242" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_EndTransformed" bpmnElement="EndEvent_Transformed">
        <dc:Bounds x="392" y="202" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="368" y="245" width="84" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_EndFailed" bpmnElement="EndEvent_TransformFailed">
        <dc:Bounds x="392" y="322" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="368" y="365" width="84" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_ToTransform" bpmnElement="Flow_ToTransform">
        <di:waypoint x="188" y="220"/><di:waypoint x="240" y="220"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_ToEnd" bpmnElement="Flow_ToEnd">
        <di:waypoint x="340" y="220"/><di:waypoint x="392" y="220"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_ToErrorEnd" bpmnElement="Flow_ToErrorEnd">
        <di:waypoint x="290" y="278"/><di:waypoint x="290" y="340"/><di:waypoint x="392" y="340"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>

<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:operaton="http://operaton.org/schema/1.0/bpmn"
                  id="Definitions_OrderFulfillment"
                  targetNamespace="http://operaton.org/examples/order-fulfillment">

  <bpmn:error id="Error_OutOfStock" name="Out of stock" errorCode="OUT_OF_STOCK"/>

  <bpmn:process id="order-fulfillment"
                name="Order Fulfillment"
                isExecutable="true"
                operaton:historyTimeToLive="P30D">

    <bpmn:startEvent id="StartEvent_OrderPlaced" name="Order placed">
      <bpmn:outgoing>Flow_Start_To_Check</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:sequenceFlow id="Flow_Start_To_Check"
                       sourceRef="StartEvent_OrderPlaced"
                       targetRef="ServiceTask_CheckInventory"/>

    <bpmn:serviceTask id="ServiceTask_CheckInventory"
                      name="Check inventory"
                      operaton:type="external"
                      operaton:topic="inventory-check">
      <bpmn:incoming>Flow_Start_To_Check</bpmn:incoming>
      <bpmn:outgoing>Flow_Check_To_Ship</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:boundaryEvent id="BoundaryEvent_OutOfStock"
                        name="Out of stock"
                        attachedToRef="ServiceTask_CheckInventory">
      <bpmn:outgoing>Flow_OutOfStock_To_End</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrDef_OutOfStock" errorRef="Error_OutOfStock"/>
    </bpmn:boundaryEvent>

    <bpmn:sequenceFlow id="Flow_OutOfStock_To_End"
                       sourceRef="BoundaryEvent_OutOfStock"
                       targetRef="EndEvent_OrderBackordered"/>

    <bpmn:endEvent id="EndEvent_OrderBackordered" name="Order backordered">
      <bpmn:incoming>Flow_OutOfStock_To_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Check_To_Ship"
                       sourceRef="ServiceTask_CheckInventory"
                       targetRef="ServiceTask_ArrangeShipping"/>

    <bpmn:serviceTask id="ServiceTask_ArrangeShipping"
                      name="Arrange shipping"
                      operaton:type="external"
                      operaton:topic="arrange-shipping">
      <bpmn:incoming>Flow_Check_To_Ship</bpmn:incoming>
      <bpmn:outgoing>Flow_Ship_To_End</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sequenceFlow id="Flow_Ship_To_End"
                       sourceRef="ServiceTask_ArrangeShipping"
                       targetRef="EndEvent_OrderFulfilled"/>

    <bpmn:endEvent id="EndEvent_OrderFulfilled" name="Order fulfilled">
      <bpmn:incoming>Flow_Ship_To_End</bpmn:incoming>
    </bpmn:endEvent>
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="order-fulfillment">

      <bpmndi:BPMNShape id="Shape_Start" bpmnElement="StartEvent_OrderPlaced">
        <dc:Bounds x="152" y="162" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="136" y="205" width="68" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_CheckInventory" bpmnElement="ServiceTask_CheckInventory">
        <dc:Bounds x="240" y="140" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_OutOfStock" bpmnElement="BoundaryEvent_OutOfStock">
        <dc:Bounds x="272" y="202" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="252" y="245" width="76" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_ArrangeShipping" bpmnElement="ServiceTask_ArrangeShipping">
        <dc:Bounds x="420" y="140" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_OrderFulfilled" bpmnElement="EndEvent_OrderFulfilled">
        <dc:Bounds x="592" y="162" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="567" y="205" width="87" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_OrderBackordered" bpmnElement="EndEvent_OrderBackordered">
        <dc:Bounds x="272" y="322" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="247" y="365" width="87" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Edge_Start_To_Check" bpmnElement="Flow_Start_To_Check">
        <di:waypoint x="188" y="180"/>
        <di:waypoint x="240" y="180"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_Check_To_Ship" bpmnElement="Flow_Check_To_Ship">
        <di:waypoint x="340" y="180"/>
        <di:waypoint x="420" y="180"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_Ship_To_End" bpmnElement="Flow_Ship_To_End">
        <di:waypoint x="520" y="180"/>
        <di:waypoint x="592" y="180"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_OutOfStock_To_End" bpmnElement="Flow_OutOfStock_To_End">
        <di:waypoint x="290" y="238"/>
        <di:waypoint x="290" y="322"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>

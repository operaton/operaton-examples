<?xml version='1.0' encoding='utf-8'?>
<dmn:definitions xmlns:dmn="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:operaton="http://operaton.org/schema/1.0/dmn" id="credit-decision-drg" name="Credit Decision DRG" namespace="http://operaton.org/examples/credit-decision">
    <dmn:decision id="risk-level" name="Risk Level Assessment" operaton:historyTimeToLive="30">
        <dmn:decisionTable id="dt_risk_level">
            <dmn:input id="input_creditScore" label="Credit Score">
                <dmn:inputExpression id="inputExpr_creditScore" typeRef="integer">
                    <dmn:text>creditScore</dmn:text>
                </dmn:inputExpression>
            </dmn:input>
            <dmn:output id="output_riskLevel" label="Risk Level" name="riskLevel" typeRef="string" />
            <dmn:rule id="rule_risk_low">
                <dmn:inputEntry id="ie_risk_low">
                    <dmn:text>&gt;= 700</dmn:text>
                </dmn:inputEntry>
                <dmn:outputEntry id="oe_risk_low">
                    <dmn:text>"LOW"</dmn:text>
                </dmn:outputEntry>
            </dmn:rule>
            <dmn:rule id="rule_risk_medium">
                <dmn:inputEntry id="ie_risk_medium">
                    <dmn:text>[600..699]</dmn:text>
                </dmn:inputEntry>
                <dmn:outputEntry id="oe_risk_medium">
                    <dmn:text>"MEDIUM"</dmn:text>
                </dmn:outputEntry>
            </dmn:rule>
            <dmn:rule id="rule_risk_high">
                <dmn:inputEntry id="ie_risk_high">
                    <dmn:text>&lt; 600</dmn:text>
                </dmn:inputEntry>
                <dmn:outputEntry id="oe_risk_high">
                    <dmn:text>"HIGH"</dmn:text>
                </dmn:outputEntry>
            </dmn:rule>
        </dmn:decisionTable>
    </dmn:decision>
    <dmn:decision id="credit-decision" name="Credit Decision" operaton:historyTimeToLive="30">
        <dmn:informationRequirement id="ir_uses_risk">
            <dmn:requiredDecision href="#risk-level" />
        </dmn:informationRequirement>
        <dmn:decisionTable id="dt_credit_decision" hitPolicy="FIRST">
            <dmn:input id="input_riskLevel" label="Risk Level">
                <dmn:inputExpression id="inputExpr_riskLevel" typeRef="string">
                    <dmn:text>riskLevel</dmn:text>
                </dmn:inputExpression>
            </dmn:input>
            <dmn:input id="input_requestedAmount" label="Requested Amount">
                <dmn:inputExpression id="inputExpr_amount" typeRef="integer">
                    <dmn:text>requestedAmount</dmn:text>
                </dmn:inputExpression>
            </dmn:input>
            <dmn:output id="output_loanDecision" label="Loan Decision" name="loanDecision" typeRef="string" />
            <dmn:rule id="rule_high_declined">
                <dmn:inputEntry id="ie_high_r">
                    <dmn:text>"HIGH"</dmn:text>
                </dmn:inputEntry>
                <dmn:inputEntry id="ie_high_a">
                    <dmn:text />
                </dmn:inputEntry>
                <dmn:outputEntry id="oe_high">
                    <dmn:text>"declined"</dmn:text>
                </dmn:outputEntry>
            </dmn:rule>
            <dmn:rule id="rule_low_approved">
                <dmn:inputEntry id="ie_low_r">
                    <dmn:text>"LOW"</dmn:text>
                </dmn:inputEntry>
                <dmn:inputEntry id="ie_low_a">
                    <dmn:text />
                </dmn:inputEntry>
                <dmn:outputEntry id="oe_low">
                    <dmn:text>"approved"</dmn:text>
                </dmn:outputEntry>
            </dmn:rule>
            <dmn:rule id="rule_medium_small_approved">
                <dmn:inputEntry id="ie_med_r1">
                    <dmn:text>"MEDIUM"</dmn:text>
                </dmn:inputEntry>
                <dmn:inputEntry id="ie_med_a1">
                    <dmn:text>&lt;= 50000</dmn:text>
                </dmn:inputEntry>
                <dmn:outputEntry id="oe_med1">
                    <dmn:text>"approved"</dmn:text>
                </dmn:outputEntry>
            </dmn:rule>
            <dmn:rule id="rule_medium_large_review">
                <dmn:inputEntry id="ie_med_r2">
                    <dmn:text>"MEDIUM"</dmn:text>
                </dmn:inputEntry>
                <dmn:inputEntry id="ie_med_a2">
                    <dmn:text>&gt; 50000</dmn:text>
                </dmn:inputEntry>
                <dmn:outputEntry id="oe_med2">
                    <dmn:text>"review"</dmn:text>
                </dmn:outputEntry>
            </dmn:rule>
        </dmn:decisionTable>
    </dmn:decision>
</dmn:definitions>
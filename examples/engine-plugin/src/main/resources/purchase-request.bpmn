<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:operaton="http://operaton.org/schema/1.0/bpmn" id="Definitions_PurchaseRequest" targetNamespace="http://operaton.org/examples">
  <bpmn:process id="purchase-request" name="Purchase Request" isExecutable="true" operaton:historyTimeToLive="P30D">
    <bpmn:startEvent id="StartEvent_RequestReceived" name="Request received">
      <bpmn:outgoing>Flow_ToCheckBudget</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="ServiceTask_CheckBudget" name="Check budget" operaton:delegateExpression="${checkBudgetDelegate}">
      <bpmn:incoming>Flow_ToCheckBudget</bpmn:incoming>
      <bpmn:outgoing>Flow_ToGateway</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_BudgetAvailable" name="Budget available?" default="Flow_BudgetNotAvailable">
      <bpmn:incoming>Flow_ToGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_BudgetAvailable</bpmn:outgoing>
      <bpmn:outgoing>Flow_BudgetNotAvailable</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="UserTask_ManagerApproval" name="Manager approval" operaton:candidateGroups="managers">
      <bpmn:incoming>Flow_BudgetAvailable</bpmn:incoming>
      <bpmn:outgoing>Flow_ToApproved</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_Approved" name="Approved">
      <bpmn:incoming>Flow_ToApproved</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_Rejected" name="Rejected">
      <bpmn:incoming>Flow_BudgetNotAvailable</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_ToCheckBudget" sourceRef="StartEvent_RequestReceived" targetRef="ServiceTask_CheckBudget" />
    <bpmn:sequenceFlow id="Flow_ToGateway" sourceRef="ServiceTask_CheckBudget" targetRef="Gateway_BudgetAvailable" />
    <bpmn:sequenceFlow id="Flow_BudgetAvailable" name="yes" sourceRef="Gateway_BudgetAvailable" targetRef="UserTask_ManagerApproval">
      <bpmn:conditionExpression xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="bpmn:tFormalExpression">${budgetAvailable}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_BudgetNotAvailable" name="no" sourceRef="Gateway_BudgetAvailable" targetRef="EndEvent_Rejected" />
    <bpmn:sequenceFlow id="Flow_ToApproved" sourceRef="UserTask_ManagerApproval" targetRef="EndEvent_Approved" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_PurchaseRequest">
    <bpmndi:BPMNPlane id="BPMNPlane_PurchaseRequest" bpmnElement="purchase-request">
      <bpmndi:BPMNShape id="Shape_Start" bpmnElement="StartEvent_RequestReceived">
        <dc:Bounds x="152" y="202" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_CheckBudget" bpmnElement="ServiceTask_CheckBudget">
        <dc:Bounds x="240" y="180" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_GwBudget" bpmnElement="Gateway_BudgetAvailable" isMarkerVisible="true">
        <dc:Bounds x="395" y="195" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="376" y="171" width="88" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_ManagerApproval" bpmnElement="UserTask_ManagerApproval">
        <dc:Bounds x="500" y="180" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_EndApproved" bpmnElement="EndEvent_Approved">
        <dc:Bounds x="662" y="202" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_EndRejected" bpmnElement="EndEvent_Rejected">
        <dc:Bounds x="662" y="312" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="658" y="348" width="44" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_ToCheckBudget" bpmnElement="Flow_ToCheckBudget">
        <di:waypoint x="188" y="220" />
        <di:waypoint x="240" y="220" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_ToGateway" bpmnElement="Flow_ToGateway">
        <di:waypoint x="340" y="220" />
        <di:waypoint x="395" y="220" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_BudgetAvailable" bpmnElement="Flow_BudgetAvailable">
        <di:waypoint x="445" y="220" />
        <di:waypoint x="500" y="220" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_BudgetNotAvailable" bpmnElement="Flow_BudgetNotAvailable">
        <di:waypoint x="420" y="245" />
        <di:waypoint x="420" y="330" />
        <di:waypoint x="662" y="330" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="466" y="307" width="13" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_ToApproved" bpmnElement="Flow_ToApproved">
        <di:waypoint x="600" y="220" />
        <di:waypoint x="662" y="220" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>

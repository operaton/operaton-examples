<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xmlns:operaton="http://operaton.org/schema/1.0/bpmn"
                  id="definitions-approval"
                  targetNamespace="http://operaton.org/examples/approval-sla-metrics">
  <bpmn:process id="purchase-requisition-approval" name="Purchase Requisition Approval"
                isExecutable="true" operaton:historyTimeToLive="P30D">

    <bpmn:startEvent id="requisition-raised" name="Requisition raised">
      <bpmn:outgoing>flow-start</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:businessRuleTask id="determine-routing" name="Determine routing"
        operaton:decisionRef="purchase-requisition-routing"
        operaton:mapDecisionResult="singleResult"
        operaton:resultVariable="routingResult">
      <bpmn:extensionElements>
        <operaton:executionListener event="end" expression="${execution.setVariable('approvalTier', routingResult.approvalTier)}"/>
        <operaton:executionListener event="end" expression="${execution.setVariable('slaDuration', routingResult.slaDuration)}"/>
        <operaton:executionListener event="end" expression="${execution.setVariable('approverGroup', routingResult.approverGroup)}"/>
      </bpmn:extensionElements>
      <bpmn:incoming>flow-start</bpmn:incoming>
      <bpmn:outgoing>flow-to-needs-approval</bpmn:outgoing>
    </bpmn:businessRuleTask>

    <bpmn:sequenceFlow id="flow-to-needs-approval" sourceRef="determine-routing" targetRef="needs-approval"/>

    <bpmn:exclusiveGateway id="needs-approval" name="Needs approval?" default="flow-to-approval">
      <bpmn:incoming>flow-to-needs-approval</bpmn:incoming>
      <bpmn:outgoing>flow-auto</bpmn:outgoing>
      <bpmn:outgoing>flow-to-approval</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sequenceFlow id="flow-auto" name="auto-approve" sourceRef="needs-approval" targetRef="end-approved">
      <bpmn:extensionElements>
        <operaton:executionListener event="take" expression="${execution.setVariable('approved', true)}"/>
      </bpmn:extensionElements>
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${approvalTier == "auto"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="flow-to-approval" name="needs review" sourceRef="needs-approval" targetRef="approve-requisition"/>

    <bpmn:userTask id="approve-requisition" name="Approve requisition"
        operaton:candidateGroups="${approverGroup}">
      <bpmn:extensionElements>
        <operaton:taskListener event="create" delegateExpression="${approvalTaskMetricsListener}"/>
        <operaton:taskListener event="complete" delegateExpression="${approvalTaskMetricsListener}"/>
      </bpmn:extensionElements>
      <bpmn:incoming>flow-to-approval</bpmn:incoming>
      <bpmn:outgoing>flow-to-approved-gw</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:boundaryEvent id="sla-timer" name="SLA deadline exceeded" cancelActivity="false" attachedToRef="approve-requisition">
      <bpmn:outgoing>flow-breach</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">${slaDuration}</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:sequenceFlow id="flow-breach" sourceRef="sla-timer" targetRef="record-sla-breach"/>

    <bpmn:serviceTask id="record-sla-breach" name="Record SLA breach"
        operaton:delegateExpression="${slaBreachDelegate}">
      <bpmn:incoming>flow-breach</bpmn:incoming>
      <bpmn:outgoing>flow-breach-end</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sequenceFlow id="flow-breach-end" sourceRef="record-sla-breach" targetRef="sla-breach-recorded"/>

    <bpmn:endEvent id="sla-breach-recorded" name="SLA breach recorded">
      <bpmn:incoming>flow-breach-end</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:exclusiveGateway id="approved-gw" name="Approved?" default="flow-rejected">
      <bpmn:incoming>flow-to-approved-gw</bpmn:incoming>
      <bpmn:outgoing>flow-approved</bpmn:outgoing>
      <bpmn:outgoing>flow-rejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sequenceFlow id="flow-to-approved-gw" sourceRef="approve-requisition" targetRef="approved-gw"/>

    <bpmn:sequenceFlow id="flow-approved" name="approved" sourceRef="approved-gw" targetRef="end-approved">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${approved == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="flow-rejected" name="rejected" sourceRef="approved-gw" targetRef="end-rejected"/>

    <bpmn:endEvent id="end-approved" name="Approved">
      <bpmn:extensionElements>
        <operaton:executionListener event="start" delegateExpression="${requisitionOutcomeListener}"/>
      </bpmn:extensionElements>
      <bpmn:incoming>flow-auto</bpmn:incoming>
      <bpmn:incoming>flow-approved</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="end-rejected" name="Rejected">
      <bpmn:extensionElements>
        <operaton:executionListener event="start" delegateExpression="${requisitionOutcomeListener}"/>
      </bpmn:extensionElements>
      <bpmn:incoming>flow-rejected</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="flow-start" sourceRef="requisition-raised" targetRef="determine-routing"/>
  </bpmn:process>

  <bpmndi:BPMNDiagram id="diagram">
    <bpmndi:BPMNPlane id="plane" bpmnElement="purchase-requisition-approval">
      <bpmndi:BPMNShape id="s_start" bpmnElement="requisition-raised">
        <dc:Bounds x="160" y="180" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="142" y="223" width="76" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_routing" bpmnElement="determine-routing">
        <dc:Bounds x="250" y="158" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_needs" bpmnElement="needs-approval" isMarkerVisible="true">
        <dc:Bounds x="405" y="173" width="50" height="50"/>
        <bpmndi:BPMNLabel><dc:Bounds x="398" y="143" width="66" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_approve" bpmnElement="approve-requisition">
        <dc:Bounds x="510" y="158" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_slatimer" bpmnElement="sla-timer">
        <dc:Bounds x="542" y="220" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="520" y="263" width="84" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_breach" bpmnElement="record-sla-breach">
        <dc:Bounds x="490" y="320" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_breachend" bpmnElement="sla-breach-recorded">
        <dc:Bounds x="652" y="342" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="630" y="385" width="82" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_approvedgw" bpmnElement="approved-gw" isMarkerVisible="true">
        <dc:Bounds x="665" y="173" width="50" height="50"/>
        <bpmndi:BPMNLabel><dc:Bounds x="668" y="143" width="56" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_endapproved" bpmnElement="end-approved">
        <dc:Bounds x="782" y="180" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="775" y="223" width="50" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_endrejected" bpmnElement="end-rejected">
        <dc:Bounds x="672" y="260" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="668" y="303" width="46" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="e_start" bpmnElement="flow-start">
        <di:waypoint x="196" y="198"/><di:waypoint x="250" y="198"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="e_needs" bpmnElement="flow-to-needs-approval">
        <di:waypoint x="350" y="198"/><di:waypoint x="405" y="198"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="e_auto" bpmnElement="flow-auto">
        <di:waypoint x="430" y="173"/><di:waypoint x="430" y="100"/>
        <di:waypoint x="800" y="100"/><di:waypoint x="800" y="180"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="e_toapproval" bpmnElement="flow-to-approval">
        <di:waypoint x="455" y="198"/><di:waypoint x="510" y="198"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="e_breach" bpmnElement="flow-breach">
        <di:waypoint x="560" y="256"/><di:waypoint x="560" y="320"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="e_breachend" bpmnElement="flow-breach-end">
        <di:waypoint x="590" y="360"/><di:waypoint x="652" y="360"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="e_toapprovedgw" bpmnElement="flow-to-approved-gw">
        <di:waypoint x="610" y="198"/><di:waypoint x="665" y="198"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="e_approved" bpmnElement="flow-approved">
        <di:waypoint x="715" y="198"/><di:waypoint x="782" y="198"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="e_rejected" bpmnElement="flow-rejected">
        <di:waypoint x="690" y="223"/><di:waypoint x="690" y="260"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>

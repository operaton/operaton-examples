<?xml version='1.0' encoding='utf-8'?>
<dmn:definitions xmlns:dmn="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:operaton="http://operaton.org/schema/1.0/dmn" id="purchase-requisition-routing-definitions" name="Purchase Requisition Routing" namespace="http://operaton.org/examples/approval-sla-metrics">
    <dmn:description>sds</dmn:description>
    <dmn:decision id="purchase-requisition-routing" name="Purchase Requisition Routing" operaton:historyTimeToLive="30">
        <dmn:decisionTable id="decisionTable_routing" hitPolicy="FIRST">
            <dmn:input id="input_amount" label="Amount">
                <dmn:inputExpression id="inputExpression_amount" typeRef="double">
                    <dmn:text>amount</dmn:text>
                </dmn:inputExpression>
            </dmn:input>
            <dmn:output id="output_tier" label="Approval Tier" name="approvalTier" typeRef="string" />
            <dmn:output id="output_sla" label="SLA Duration" name="slaDuration" typeRef="string" />
            <dmn:output id="output_group" label="Approver Group" name="approverGroup" typeRef="string" />
            <dmn:rule id="rule_auto">
                <dmn:inputEntry id="ie_auto">
                    <dmn:text>&lt; 1000</dmn:text>
                </dmn:inputEntry>
                <dmn:outputEntry id="oe_auto_tier">
                    <dmn:text>"auto"</dmn:text>
                </dmn:outputEntry>
                <dmn:outputEntry id="oe_auto_sla">
                    <dmn:text>"PT0S"</dmn:text>
                </dmn:outputEntry>
                <dmn:outputEntry id="oe_auto_group">
                    <dmn:text>""</dmn:text>
                </dmn:outputEntry>
            </dmn:rule>
            <dmn:rule id="rule_manager">
                <dmn:inputEntry id="ie_manager">
                    <dmn:text>&lt; 10000</dmn:text>
                </dmn:inputEntry>
                <dmn:outputEntry id="oe_manager_tier">
                    <dmn:text>"manager"</dmn:text>
                </dmn:outputEntry>
                <dmn:outputEntry id="oe_manager_sla">
                    <dmn:text>"PT5S"</dmn:text>
                </dmn:outputEntry>
                <dmn:outputEntry id="oe_manager_group">
                    <dmn:text>"managers"</dmn:text>
                </dmn:outputEntry>
            </dmn:rule>
            <dmn:rule id="rule_director">
                <dmn:inputEntry id="ie_director">
                    <dmn:text />
                </dmn:inputEntry>
                <dmn:outputEntry id="oe_director_tier">
                    <dmn:text>"director"</dmn:text>
                </dmn:outputEntry>
                <dmn:outputEntry id="oe_director_sla">
                    <dmn:text>"PT2S"</dmn:text>
                </dmn:outputEntry>
                <dmn:outputEntry id="oe_director_group">
                    <dmn:text>"directors"</dmn:text>
                </dmn:outputEntry>
            </dmn:rule>
        </dmn:decisionTable>
    </dmn:decision>
</dmn:definitions>
<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:operaton="http://operaton.org/schema/1.0/bpmn" id="Definitions_OrderOrchestration" targetNamespace="http://operaton.org/examples">
  <bpmn:process id="order-orchestration" name="Order Orchestration" isExecutable="true" operaton:historyTimeToLive="P30D">
    <bpmn:documentation>A parent process that orchestrates order processing via callActivity, delegating to reusable child process definitions and passing variables in and out through operaton:in and operaton:out mappings.

Copyright 2026 the Operaton contributors. Licensed under the Apache License, Version 2.0 (the "License"); you may not use this file except in compliance with the License. You may obtain a copy of the License at http://www.apache.org/licenses/LICENSE-2.0</bpmn:documentation>
    <bpmn:startEvent id="StartEvent_OrderReceived" name="Order received">
      <bpmn:outgoing>Flow_Start_Validate</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:callActivity id="CallActivity_Validate" name="Validate order" calledElement="validate-order">
      <bpmn:extensionElements>
        <operaton:in source="orderId" target="orderId" />
        <operaton:out source="isValid" target="orderValid" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Start_Validate</bpmn:incoming>
      <bpmn:outgoing>Flow_Validate_Gateway</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:exclusiveGateway id="Gateway_Valid" name="Order valid?" default="Flow_Valid_Notify">
      <bpmn:incoming>Flow_Validate_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Valid_Notify</bpmn:outgoing>
      <bpmn:outgoing>Flow_Invalid_End</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:callActivity id="CallActivity_Notify" name="Notify customer" calledElement="notify-customer">
      <bpmn:extensionElements>
        <operaton:in source="customerEmail" target="customerEmail" />
        <operaton:in source="orderId" target="orderId" />
        <operaton:out source="notified" target="customerNotified" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Valid_Notify</bpmn:incoming>
      <bpmn:outgoing>Flow_Notify_End</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:endEvent id="EndEvent_Confirmed" name="Order confirmed">
      <bpmn:incoming>Flow_Notify_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_InvalidOrder" name="Order invalid">
      <bpmn:incoming>Flow_Invalid_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_Validate" sourceRef="StartEvent_OrderReceived" targetRef="CallActivity_Validate" />
    <bpmn:sequenceFlow id="Flow_Validate_Gateway" sourceRef="CallActivity_Validate" targetRef="Gateway_Valid" />
    <bpmn:sequenceFlow id="Flow_Valid_Notify" name="valid" sourceRef="Gateway_Valid" targetRef="CallActivity_Notify" />
    <bpmn:sequenceFlow id="Flow_Invalid_End" name="invalid" sourceRef="Gateway_Valid" targetRef="EndEvent_InvalidOrder">
      <bpmn:conditionExpression>${orderValid == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Notify_End" sourceRef="CallActivity_Notify" targetRef="EndEvent_Confirmed" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_OrderOrchestration">
    <bpmndi:BPMNPlane id="BPMNPlane_OrderOrchestration" bpmnElement="order-orchestration">
      <bpmndi:BPMNShape id="Shape_Start" bpmnElement="StartEvent_OrderReceived">
        <dc:Bounds x="152" y="222" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="133" y="263" width="73" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_CallValidate" bpmnElement="CallActivity_Validate">
        <dc:Bounds x="240" y="200" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_GwValid" bpmnElement="Gateway_Valid" isMarkerVisible="true">
        <dc:Bounds x="395" y="215" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="390" y="193" width="60" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_CallNotify" bpmnElement="CallActivity_Notify">
        <dc:Bounds x="500" y="200" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_EndConfirmed" bpmnElement="EndEvent_Confirmed">
        <dc:Bounds x="662" y="222" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="640" y="263" width="80" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_EndInvalid" bpmnElement="EndEvent_InvalidOrder">
        <dc:Bounds x="662" y="332" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="648" y="373" width="63" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_Start_Validate" bpmnElement="Flow_Start_Validate">
        <di:waypoint x="188" y="240" />
        <di:waypoint x="240" y="240" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Validate_Gateway" bpmnElement="Flow_Validate_Gateway">
        <di:waypoint x="340" y="240" />
        <di:waypoint x="395" y="240" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Valid_Notify" bpmnElement="Flow_Valid_Notify">
        <di:waypoint x="445" y="240" />
        <di:waypoint x="500" y="240" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Invalid_End" bpmnElement="Flow_Invalid_End">
        <di:waypoint x="420" y="265" />
        <di:waypoint x="420" y="350" />
        <di:waypoint x="662" y="350" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="434" y="298" width="32" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Notify_End" bpmnElement="Flow_Notify_End">
        <di:waypoint x="600" y="240" />
        <di:waypoint x="662" y="240" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
